ex="8" value="88"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="users" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="50"/><column index="2" value="171"/><column index="3" value="93"/><column index="4" value="179"/><column index="5" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">DROP VIEW IF EXISTS usage_enriched;

CREATE VIEW usage_enriched AS
SELECT
    l.date,
    l.user_id,
    u.company,
    u.department,
    u.role,
    l.app,
    l.sessions,
    l.minutes_used,
    l.feature_actions,
    l.errors,
    l.seat_cost_usd
FROM usage_logs l
JOIN users u
ON l.user_id = u.user_id;</sql><current_tab id="0"/></tab_sql></sqlb_project>
